# Kopieren nach .env und ausfüllen. .env wird nicht ins Repo committed.

# Seit Phase 3 (Nutzerverwaltung) gibt es keinen geteilten API_KEY mehr -
# jeder Nutzer meldet sich mit E-Mail/Passwort an (siehe backend/create-admin.js
# für den ersten Administrator-Account).

# Bind-Adresse/Port des Node-Servers. 127.0.0.1 = nur lokal erreichbar,
# der Cloudflare Tunnel reicht Requests von außen lokal durch (siehe
# cloudflared/config.yml.example). NICHT auf 0.0.0.0 ändern, außer der
# Server soll direkt (ohne Tunnel) im LAN erreichbar sein.
HOST=127.0.0.1
PORT=3000

# Optional: Pfad zur SQLite-Datei (Default: backend/data/traveller.db)
# DB_PATH=/opt/traveller-charsheet/backend/data/traveller.db

# Nur für migrate-from-kv.js: Zugangsdaten zum ALTEN Cloudflare Worker,
# aus dem einmalig die Bestandsdaten übernommen werden.
# KV_URL=https://traveller-sync.<name>.workers.dev
# KV_KEY=<alter Worker API_KEY>
