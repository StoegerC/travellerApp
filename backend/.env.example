# Kopieren nach .env und ausfüllen. .env wird nicht ins Repo committed.

# Seit Phase 3 (Nutzerverwaltung) gibt es keinen geteilten API_KEY mehr -
# jeder Nutzer meldet sich mit E-Mail/Passwort an (siehe backend/create-admin.js
# für den ersten Administrator-Account).

# Bind-Adresse/Port des Node-Servers. 127.0.0.1 = nur lokal erreichbar,
# der Cloudflare Tunnel reicht Requests von außen lokal durch (siehe
# cloudflared/config.yml.example). NICHT auf 0.0.0.0 ändern, außer der
# Server soll direkt (ohne Tunnel) im LAN erreichbar sein.
HOST=127.0.0.1
PORT=3000

# Optional: Pfad zur SQLite-Datei (Default: backend/data/traveller.db)
# DB_PATH=/opt/traveller-charsheet/backend/data/traveller.db

# Optional (Sicherheit): Session laeuft nach so vielen Tagen ohne Nutzung ab
# (Default 90). Beim Serverstart werden abgelaufene Sessions aufgeraeumt.
# SESSION_IDLE_DAYS=90

# Optional (Sicherheit): Speicher-Quota pro Nutzer in Bytes - Summe aus
# Charakter-/Kampagnen-JSON und hochgeladenen Medien. Default 2 GiB
# (2147483648). 0 = unbegrenzt (Verhalten vor der Haertung).
# USER_QUOTA_BYTES=2147483648

# Nur für migrate-from-kv.js: Zugangsdaten zum ALTEN Cloudflare Worker,
# aus dem einmalig die Bestandsdaten übernommen werden.
# KV_URL=https://traveller-sync.<name>.workers.dev
# KV_KEY=<alter Worker API_KEY>

# Nur für backup-to-git.js: separates, privates Git-Repo für den täglichen
# Charakter-/Kampagnen-Snapshot (Medien-Dateien werden NICHT mitversioniert,
# siehe Kommentar im Skript). Alle drei haben sinnvolle Defaults, nur bei
# abweichendem Setup (anderes Repo, anderer Deploy-Key-Pfad) überschreiben.
# BACKUP_REPO_URL=git@github.com:StoegerC/TravellerServerBackup.git
# BACKUP_SSH_KEY=/Users/<name>/.ssh/traveller_backup_deploy
# BACKUP_DIR=/opt/traveller-charsheet/backend/data/git-backup
