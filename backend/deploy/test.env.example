# Test-Umgebung — kopieren nach /etc/traveller/test.env und ausfüllen.
# Wird von traveller@test.service geladen.

# Anderer Port als Prod. Test wird NICHT per Funnel öffentlich exponiert,
# sondern nur im Tailnet erreichbar gemacht (tailscale serve, siehe README) —
# weniger gehärteter Code soll nicht offen im Netz stehen.
HOST=127.0.0.1
PORT=3001

# Eigene Daten, strikt getrennt von Prod.
DB_PATH=/var/lib/traveller/test/traveller.db
UPLOAD_DIR=/var/lib/traveller/test/uploads

SESSION_IDLE_DAYS=90
# Kleinere Quota, um das 413-Verhalten bei Bedarf gefahrlos zu testen:
# USER_QUOTA_BYTES=524288000

# ── KEINE BACKUP-KONFIGURATION ───────────────────────────────────────────────
# Test darf das Prod-Backup-Repo NIEMALS beschreiben. Deshalb hier absichtlich
# keine BACKUP_*-Werte und kein Backup-Timer für Test.
# ACHTUNG: backend/git-backup-config.js hat einen HARTKODIERTEN Default auf das
# Prod-Repo (falls BACKUP_REPO_URL leer ist). Also: `node backup-to-git.js` auf
# dem Test-Server NIE manuell ausführen — es würde ins Prod-Repo pushen.
