# Prod-Umgebung — kopieren nach /etc/traveller/prod.env und ausfüllen.
# Wird von traveller@prod.service und traveller-backup.service geladen.
# Enthält Secrets/Pfade → nicht ins Repo committen (nur diese .example-Datei).

# Server: nur lokal binden, der Tailscale-Funnel-Tunnel reicht öffentlich durch.
HOST=127.0.0.1
PORT=3000

# Daten AUSSERHALB des Checkouts — git pull/Redeploy fasst sie nie an, und
# Prod/Test teilen physisch nichts.
DB_PATH=/var/lib/traveller/prod/traveller.db
UPLOAD_DIR=/var/lib/traveller/prod/uploads

# Sicherheit (siehe backend/.env.example für die Bedeutung)
SESSION_IDLE_DAYS=90
# USER_QUOTA_BYTES=2147483648

# ── Git-Backup (NUR Prod) ────────────────────────────────────────────────────
# Privates Repo für den täglichen JSON-Snapshot (traveller-backup.service) UND
# den Snapshot-Rollback aus der Admin-Oberfläche (der Server ruft dafür git pull
# mit diesem Key auf). Key bewusst unter /var/lib/traveller/prod/, nicht unter
# /home: die Server-Unit läuft mit ProtectHome=true und käme an /home nicht ran.
BACKUP_REPO_URL=git@github.com:StoegerC/TravellerServerBackup.git
BACKUP_SSH_KEY=/var/lib/traveller/prod/.ssh/traveller_backup_deploy
BACKUP_DIR=/var/lib/traveller/prod/git-backup
